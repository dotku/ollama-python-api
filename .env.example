# Neon Postgres
DATABASE_URL=postgresql://...@ep-xxx.neon.tech/neondb?sslmode=require

# Rate limiting
ANON_RATE_LIMIT=10         # anonymous: requests per window
MEMBER_RATE_LIMIT=30       # member: requests per window
RATE_WINDOW=60             # window in seconds

# CORS (comma-separated origins for the Vercel dashboard)
CORS_ORIGINS=https://your-dashboard.vercel.app,http://localhost:3000

# Ollama
OLLAMA_BASE=http://localhost:11434
